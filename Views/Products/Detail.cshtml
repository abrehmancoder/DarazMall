@model WebApplication1.Models.Product
@{
    ViewData["Title"] = @Model.Name;
}
<style>
    .detail-img {
        border-radius: 12px;
        object-fit: contain;
        background: #fafafa;
        border: 1px solid #eff0f5;
        padding: 20px;
        width: 100%;
        height: 380px;
    }

    .btn-add-cart {
        background-color: white;
        color: #0B2E33;
        border: 2px solid #0B2E33;
        font-weight: 600;
        border-radius: 8px;
        transition: transform 0.2s ease, background-color 0.2s;
        padding: 12px 30px;
    }

        .btn-add-cart:hover {
            background-color: #0B2E33;
            color: white;
            transform: scale(1.05);
        }

    .btn-shop-now {
        background-color: #0B2E33;
        color: white;
        font-weight: 600;
        border-radius: 8px;
        border: none;
        transition: transform 0.2s ease, background-color 0.2s;
        padding: 12px 30px;
    }

        .btn-shop-now:hover {
            background-color: #4F7C82;
            color: white;
            transform: scale(1.05);
        }

    .stars {
        color: #f5a623;
        font-size: 18px;
    }
</style>

<div class="container mt-5">
    <a asp-action="Shop" class="btn btn-outline-secondary btn-sm mb-4"
       style="border-radius:6px;">← Back to Shop</a>
    <div class="row g-5">
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="detail-img" alt="@Model.Name" />
        </div>
        <div class="col-md-6">
            <span class="badge mb-2" style="background-color:#B8E3E9; color:#0B2E33;">@Model.Category</span>
            <h2 class="fw-bold" style="color:#0B2E33;">@Model.Name</h2>
            <div class="stars mb-2">★★★★☆ <span class="text-muted small">(128 reviews)</span></div>
            <h3 class="fw-bold mb-3" style="color:#4F7C82;">Rs. @Model.Price.ToString("N0")</h3>
            <p class="text-secondary mb-4" style="line-height:1.8;">@Model.Description</p>
            <div class="d-flex gap-3 flex-wrap">
                <form asp-controller="Products" asp-action="AddToCart" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-add-cart">🛒 Add to Cart</button>
                </form>
                <form asp-controller="Products" asp-action="BuyNow" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-shop-now">⚡ Buy Now</button>
                </form>
            </div>
            <div class="mt-4 p-3" style="background:#f8f9fa; border-radius:8px;">
                <p class="mb-1 small">✅ Free delivery on orders above Rs. 2000</p>
                <p class="mb-1 small">🔄 7-day easy returns</p>
                <p class="mb-0 small">🛡️ 100% authentic products</p>
            </div>
        </div>
    </div>
</div>