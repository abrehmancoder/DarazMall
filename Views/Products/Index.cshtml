@model IEnumerable<WebApplication1.Models.Product>
@{
    ViewData["Title"] = "Admin Panel";
}
<style>
    .stat-card {
        border-radius: 12px;
        padding: 20px;
        color: white;
        font-weight: bold;
    }
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color:#0B2E33;">
            @(Context.Session.GetString("UserRole") == "SuperAdmin" ? "Super Admin Panel" : "My Products")
        </h2>
        <a asp-action="Create" class="btn text-white fw-bold" style="background-color:#0B2E33; border-radius:8px;">+ Add New Product</a>
    </div>

    <!-- Dashboard Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#0B2E33,#4F7C82);">
                <div style="font-size:28px; font-weight:800;">@ViewBag.TotalProducts</div>
                <div style="font-size:13px; opacity:0.85;">Total Products</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#4F7C82,#93B1B5);">
                <div style="font-size:28px; font-weight:800;">@ViewBag.TotalUsers</div>
                <div style="font-size:13px; opacity:0.85;">Registered Users</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#0B2E33,#93B1B5);">
                <div style="font-size:28px; font-weight:800;">@ViewBag.TotalOrders</div>
                <div style="font-size:13px; opacity:0.85;">Total Orders</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card" style="background:linear-gradient(135deg,#93B1B5,#4F7C82);">
                <div style="font-size:28px; font-weight:800;">Rs. @(((decimal)(ViewBag.TotalRevenue ?? 0m)).ToString("N0"))</div>
                <div style="font-size:13px; opacity:0.85;">Total Revenue</div>
            </div>
        </div>
    </div>

    @if (TempData["CartMessage"] != null)
    {
        <div class="alert alert-success">✓ @TempData["CartMessage"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">No products yet. Click "+ Add New Product"!</div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-3 mb-4">
                    <div class="card h-100 shadow-sm" style="border-radius:12px;">
                        <img src="@item.ImageUrl" class="card-img-top"
                             style="height:200px; object-fit:contain; padding:10px; background:#fafafa;" />
                        <div class="card-body d-flex flex-column">
                            <h6 class="fw-bold text-truncate">@item.Name</h6>
                            <p class="text-muted small mb-1">@item.Category</p>
                            <p class="fw-bold" style="color:#0B2E33;">Rs. @item.Price.ToString("N0")</p>
                            <small class="text-muted" style="font-size:10px;">By: @item.CreatedByEmail</small>
                            <div class="mt-auto pt-2 d-flex flex-column gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary fw-bold">Edit Product</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                      onsubmit="return confirm('Delete this product?');">
                                    <button type="submit" class="btn btn-sm btn-danger fw-bold w-100">Delete Product</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>