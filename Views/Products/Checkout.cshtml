@model IEnumerable<WebApplication1.Models.Product>

@{
    ViewData["Title"] = "Checkout - Daraz Mall";
    decimal grandTotal = Model.Sum(x => x.Price);
}

<div class="container mt-5" style="max-width: 900px;">
    <form onsubmit="alert('Order Placed Successfully via Cash on Delivery / Virtual Card!'); return true;" action="/Products/Shop" method="get">
        <div class="row g-4">

            <div class="col-md-7">
                <div class="card shadow-sm border-0 p-4" style="border-radius: 12px; background: #fff;">
                    <h4 class="font-weight-bold mb-4" style="color: #0B2E33; border-bottom: 2px solid #4F7C82; padding-bottom: 10px;">Shipping & Payment Details</h4>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold small text-secondary">Full Name</label>
                        <input type="text" class="form-control py-2" placeholder="Enter your full name" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold small text-secondary">Shipping Address</label>
                        <input type="text" class="form-control py-2" placeholder="House#, Street, City Area" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label font-weight-bold small text-secondary">Phone Number</label>
                        <input type="tel" pattern="[0-9]{11}" class="form-control py-2" placeholder="e.g., 03001234567 (11 digits)" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold small text-secondary">Payment Method</label>
                        <select class="form-select py-2" style="border-radius: 6px;">
                            <option value="COD">Cash on Delivery (COD)</option>
                            <option value="Card">Virtual Visa Card / NayaPay</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card shadow-sm border-0 p-4" style="border-radius: 12px; background: #fff; border-top: 4px solid #4F7C82;">
                    <h4 class="font-weight-bold mb-4" style="color: #0B2E33;">Order Summary</h4>

                    <div class="overflow-auto mb-3" style="max-height: 200px;">
                        @foreach (var item in Model)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom border-light">
                                <div style="max-width: 70%;">
                                    <span class="d-block font-weight-bold text-dark small text-truncate">@item.Name</span>
                                    <span class="badge bg-light text-secondary" style="font-size: 10px;">@item.Category</span>
                                </div>
                                <span class="text-secondary small font-weight-bold">Rs. @item.Price</span>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-between align-items-center my-3">
                        <span class="h5 font-weight-bold text-dark mb-0">Grand Total:</span>
                        <span class="h4 font-weight-bold" style="color: #4F7C82;">Rs. @grandTotal</span>
                    </div>

                    <button type="submit" class="btn text-white w-100 py-3 font-weight-bold shadow-sm mt-2" style="background-color: #4F7C82; border-radius: 8px; font-size: 16px;">
                        Place Order Now
                    </button>
                </div>
            </div>

        </div>
    </form>
</div>